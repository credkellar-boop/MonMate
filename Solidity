pragma solidity ^0.8.0;

contract ChessBet {
    struct Match {
        address player1;
        address player2;
        uint256 betAmount;
        bool active;
    }

    mapping(bytes32 => Match) public matches;

    function createMatch(bytes32 matchId, address opponent) external payable {
        matches[matchId] = Match(msg.sender, opponent, msg.value, true);
    }

    function joinMatch(bytes32 matchId) external payable {
        Match storage m = matches[matchId];
        require(msg.value == m.betAmount, "Must match the bet amount");
        // Logic to trigger game start...
    }

    // In a real app, use an Oracle or Multi-sig to verify the winner
    function settleMatch(bytes32 matchId, address winner) external {
        Match storage m = matches[matchId];
        require(m.active, "Match not active");
        m.active = false;
        payable(winner).transfer(m.betAmount * 2);
    }
}
